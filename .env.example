# Hannah English & EduMetrics - Supabase Configuration Template
# Sao chép file này, đổi tên thành `.env` và nhập thông tin dự án Supabase của bạn.

# 1. Địa chỉ URL dự án Supabase của bạn (Supabase Project URL)
# Lấy tại: Supabase Dashboard -> Settings -> API -> Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# 2. Khóa Anon Public Key của dự án (Anon Public Key)
# Lấy tại: Supabase Dashboard -> Settings -> API -> Project API keys -> anon (public)
VITE_SUPABASE_ANON_KEY=your-actual-anon-public-key
